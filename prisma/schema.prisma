generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}


enum Currency {
  TRY
  USD
  EUR
}

enum AccountStatus {
  ACTIVE
  FROZEN
  CLOSED
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  TRANSFER
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REJECTED
}

enum Action {
  DEPOSIT
  WITHDRAW
  TRANSFER
  LOGIN
  LOGOUT
  ACCOUNT_CREATE
  ACCOUNT_FREEZE
  ACCOUNT_UNFREEZE
  ACCOUNT_CLOSE
  PASSWORD_CHANGE
  REGISTER
  REFRESH
}

enum EventStatus {
  PENDING
  PROCESSED
  FAILED
}

enum AuditOutcome {
  SUCCESS
  FAILURE
}

enum FraudDecision {
  APPROVE
  REJECT
}


model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String
  phone     String
  passwordHash  String  @map("password_hash")

  failedLoginAttempts  Int      @default(0) @map("failed_login_attempts")
  lockUntil            DateTime? @map("lock_until")
  accounts  Account[]
  audit AuditLog[]
  refreshTokens RefreshToken[]
  initiatedTransactions Transaction[] @relation("TransactionActor")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("customers")
}

model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  customerId   String    @map("customer_id") @db.Uuid
  customer     Customer  @relation(fields: [customerId], references: [id])

  tokenHash    String    @map("token_hash") @unique
  deviceId     String?   @map("device_id")
  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")

  expiresAt    DateTime  @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  revokedAt    DateTime? @map("revoked_at")

  replacedById String?   @map("replaced_by_id") @db.Uuid
  replacedBy   RefreshToken? @relation("RefreshTokenReplacement", fields: [replacedById], references: [id])
  replacedTokens RefreshToken[] @relation("RefreshTokenReplacement")

  @@index([customerId])
  @@map("refresh_tokens")
}


model Account {
  id         String   @id @default(uuid()) @db.Uuid

  customerId String   @map("customer_id") @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id])

  balance    Decimal  @default(0) @db.Decimal(18,2)
  currency   Currency @default(TRY)
  status     AccountStatus @default(ACTIVE)

  createdAt  DateTime @default(now()) @map("created_at")

  transactionsFrom Transaction[] @relation("FromAccount")
  transactionsTo   Transaction[] @relation("ToAccount")

  @@index([customerId])
  @@map("accounts")
}

model Transaction {
  id            String             @id @default(uuid()) @db.Uuid
  type          TransactionType
  actorCustomerId String             @map("actor_customer_id") @db.Uuid
  actorCustomer   Customer           @relation("TransactionActor", fields: [actorCustomerId], references: [id])

  fromAccountId String?            @map("from_account") @db.Uuid
  fromAccount   Account?           @relation("FromAccount", fields: [fromAccountId], references: [id], onDelete: SetNull)
  toAccountId   String?            @map("to_account") @db.Uuid
  toAccount     Account?           @relation("ToAccount", fields: [toAccountId], references: [id], onDelete: SetNull)
  amount        Decimal            @db.Decimal(18,2)
  status        TransactionStatus  @default(PENDING)
  fraudDecision FraudDecision?
  fraudReason   String?
  referenceId   String             @map("reference_id") 
  createdAt     DateTime           @default(now()) @map("created_at")

  @@map("transactions")
  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([actorCustomerId])
  @@unique([actorCustomerId, type, referenceId])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  action     Action

  outcome    AuditOutcome? @map("outcome")

  actorId    String?       @map("actor_id") @db.Uuid
  resourceId String?       @map("resource_id") @db.Uuid
  traceId    String?       @map("trace_id")

  reasonCode String?       @map("reason_code")
  metadata   Json?         @map("metadata")

  customerId String   @map("customer_id") @db.Uuid
  user       Customer @relation(fields: [customerId], references: [id])

  entityType String   @map("entity_type")
  entityId   String   @map("entity_id") @db.Uuid

  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")

  timestamp  DateTime @default(now())

  @@map("audit_logs")
  @@index([customerId])
}

model Event {
  id        String      @id @default(uuid()) @db.Uuid
  type      String
  payload   Json
  status    EventStatus @default(PENDING)
  retryCount   Int       @default(0) @map("retry_count")
  nextRetryAt  DateTime? @map("next_retry_at")
  lastError    String?   @map("last_error")
  publishedAt  DateTime? @map("published_at")

  createdAt DateTime    @default(now()) @map("created_at")

  @@map("events")
  @@index([status, createdAt])
  @@index([status, nextRetryAt])
}

model ProcessedMessage {
  id         String   @id @default(uuid()) @db.Uuid
  messageId  String   @map("message_id")
  eventType  String   @map("event_type")
  consumer   String
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("processed_messages")
  @@unique([consumer, messageId])
  @@index([processedAt])
}