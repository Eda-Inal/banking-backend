generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}


enum Currency {
  TRY
  USD
  EUR
}

enum AccountStatus {
  ACTIVE
  FROZEN
  CLOSED
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  TRANSFER
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REJECTED
}

enum Action {
  DEPOSIT
  WITHDRAW
  TRANSFER
  LOGIN
  LOGOUT
}

enum EventStatus {
  PENDING
  PROCESSED
  FAILED
}
enum TokenBlacklistType{
  ACCESS
  REFRESH
}

model Customer {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  phone     String
  passwordHash  String  @map("password_hash")
  accounts  Account[]
  audit AuditLog[]
  tokenBlacklist TokenBlacklist[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("customers")
}

model TokenBlacklist {
  id          String   @id @default(uuid())
  jti         String   @unique
  customerId  String   @map("customer_id")
  customer    Customer @relation(fields: [customerId], references: [id])
  tokenType   TokenBlacklistType @map("token_type")
  revokedAt   DateTime @default(now()) @map("revoked_at")
  expiresAt   DateTime @map("expires_at")
  deviceInfo  String?  @map("device_info")
  ipAddress   String?  @map("ip_address")
  reason      String?

  @@map("token_blacklist")
}

model Account {
  id         String   @id @default(uuid())

  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id])

  balance    Decimal  @default(0) @db.Decimal(18,2)
  currency   Currency @default(TRY)
  status     AccountStatus @default(ACTIVE)

  createdAt  DateTime @default(now()) @map("created_at")

  @@index([customerId])
  @@map("accounts")
}

model Transaction {
  id          String             @id @default(uuid())
  type        TransactionType   
  fromAccount String?            @map("from_account")
  toAccount   String?            @map("to_account")
  amount      Decimal            @db.Decimal(18,2)
  status      TransactionStatus  @default(PENDING)
  referenceId String             @map("reference_id")
  createdAt   DateTime           @default(now()) @map("created_at")

  @@map("transactions")
  @@index([fromAccount])
  @@index([toAccount])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     Action

  customerId String   @map("customer_id")
  user       Customer @relation(fields: [customerId], references: [id])

  entityType String   @map("entity_type")
  entityId   String   @map("entity_id") @db.Uuid

  timestamp  DateTime @default(now())

  @@map("audit_logs")
  @@index([customerId])
}

model Event {
  id        String      @id @default(uuid()) @db.Uuid
  type      String
  payload   Json
  status    EventStatus @default(PENDING)
  createdAt DateTime    @default(now()) @map("created_at")

  @@map("events")
}