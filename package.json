{
  "name": "backend-app",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config ./test/jest-e2e.json",
    "test:e2e:app": "npm run test:e2e -- --testPathPatterns=app.e2e-spec --runInBand",
    "test:e2e:auth": "npm run test:e2e -- --testPathPatterns=auth.e2e-spec --runInBand",
    "test:e2e:users": "npm run test:e2e -- --testPathPatterns=users.e2e-spec --runInBand",
    "test:e2e:accounts": "npm run test:e2e -- --testPathPatterns=accounts.e2e-spec --runInBand",
    "test:e2e:transactions": "npm run test:e2e -- --testPathPatterns=transactions.e2e-spec --runInBand",
    "test:e2e:contract": "npm run test:e2e -- --testPathPatterns=response-contract.e2e-spec --runInBand",
    "test:e2e:core": "npm run test:e2e -- --testPathPatterns=\"app.e2e-spec|auth.e2e-spec|users.e2e-spec|accounts.e2e-spec|transactions.e2e-spec|response-contract.e2e-spec\" --runInBand",
    "test:integration:db": "npm run test:e2e -- --testPathPatterns=transactions-db.e2e-spec --runInBand",
    "test:integration:auth": "npm run test:e2e -- --testPathPatterns=auth-token-lifecycle.e2e-spec --runInBand",
    "test:integration:accounts": "npm run test:e2e -- --testPathPatterns=account-invariants.e2e-spec --runInBand",
    "test:integration:redis": "npm run test:e2e -- --testPathPatterns=redis-controls.e2e-spec --runInBand",
    "test:integration": "npm run test:e2e -- --testPathPatterns=\"transactions-db.e2e-spec|auth-token-lifecycle.e2e-spec|account-invariants.e2e-spec|redis-controls.e2e-spec\" --runInBand",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "amqplib": "^0.10.9",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.0",
    "ioredis": "^5.10.0",
    "nest-winston": "^1.10.2",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
