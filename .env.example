NODE_ENV=development
PORT=3000
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=banking
POSTGRES_PORT=5433
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/banking
REDIS_URL=redis://redis:6379
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
OUTBOX_BATCH_SIZE=20
OUTBOX_POLL_INTERVAL_MS=2000
JWT_SECRET=RANDOM_SECRET_KEY
JWT_ACCESS_EXPIRES_IN=900 # 15 minutes (seconds)
JWT_REFRESH_EXPIRES_IN=3600 # 1 hour (seconds)
LOGIN_LOCK_THRESHOLD=5
LOGIN_LOCK_DURATION_MINUTES=15
LOGIN_DELAY_CAP_SECONDS=30
LOGIN_RATE_LIMIT_IP_PER_MINUTE=20
LOGIN_RATE_LIMIT_EMAIL_PER_MINUTE=10
TRANSACTIONS_TRANSFER_RATE_LIMIT_PER_MINUTE=10
OUTBOX_MAX_RETRIES=5
OUTBOX_RETRY_BASE_DELAY_MS=1000
OUTBOX_CLAIM_TTL_MS=300000
RABBITMQ_EVENTS_EXCHANGE=banking.events
RABBITMQ_EVENTS_QUEUE=banking.events.q
RABBITMQ_EVENTS_DLX=banking.events.dlx
RABBITMQ_EVENTS_DLQ=banking.events.dlq
RABBITMQ_CONSUMER_CLAIM_TTL_MS=300000
RABBITMQ_CONSUMER_PREFETCH=10
RABBITMQ_CONSUMER_MAX_RETRIES=5
ALERT_OUTBOX_PENDING_THRESHOLD=100
ALERT_OUTBOX_FAILED_THRESHOLD=20
ALERT_CONSUMER_NACK_THRESHOLD=10
FRAUD_TRANSFER_MAX_AMOUNT=100000
FRAUD_WITHDRAW_MAX_AMOUNT=50000
FRAUD_DAILY_TRANSFER_LIMIT=250000
FRAUD_DAILY_WITHDRAW_LIMIT=100000
FRAUD_TRANSFERS_PER_MINUTE_LIMIT=5
TRANSACTIONS_IDEMPOTENCY_IN_FLIGHT_TTL_SEC=180
GLOBAL_RATE_LIMIT_PER_MINUTE=100

