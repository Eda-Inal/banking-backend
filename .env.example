NODE_ENV=development
PORT=3000
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=banking
POSTGRES_PORT=5433
REDIS_URL=redis://redis:6379
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
JWT_SECRET=RANDOM_SECRET_KEY
JWT_ACCESS_EXPIRES_IN=15 # 15 minutes
JWT_REFRESH_EXPIRES_IN=60 # 1 hour
# Login lock & progressive delay
LOGIN_LOCK_THRESHOLD=5
LOGIN_LOCK_DURATION_MINUTES=15
LOGIN_DELAY_CAP_SECONDS=30
# Login rate limit
LOGIN_RATE_LIMIT_IP_PER_MINUTE=20
LOGIN_RATE_LIMIT_EMAIL_PER_MINUTE=10


